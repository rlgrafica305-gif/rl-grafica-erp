APP_NAME="RL Gráfica ERP"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://seu-backend.up.railway.app

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=rl_grafica
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_CONNECTION=log
CACHE_STORE=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false

# Railway MySQL fornece automaticamente via variável MYSQL_URL
# DB_URL=${MYSQL_URL}

# CORS — URL do frontend (Vercel)
FRONTEND_URL=https://seu-frontend.vercel.app

SANCTUM_STATEFUL_DOMAINS=seu-frontend.vercel.app,localhost:5173
SESSION_DOMAIN=.railway.app

MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@rlgrafica.com.br"
MAIL_FROM_NAME="${APP_NAME}"
